{
  "name": "presell-server",
  "version": "1.0.0",
  "description": "Server-side presell manager for affiliate bridge pages.",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "start": "npm run start:split",
    "start:backend": "npm run start --workspace backend --if-present --",
    "start:frontend": "npm run start --workspace frontend --if-present --",
    "start:split": "node scripts/run-split.js start",
    "dev": "npm run dev:split",
    "dev:backend": "npm run dev --workspace backend --if-present --",
    "dev:frontend": "npm run dev --workspace frontend --if-present --",
    "dev:split": "node scripts/run-split.js dev",
    "hash-password": "node scripts/hash-password.js",
    "smoke": "node scripts/smoke.js",
    "build": "npm run build:split",
    "build:templates": "node scripts/build-templates.js",
    "build:backend": "npm run build --workspace backend --if-present --",
    "build:frontend": "npm run build --workspace frontend --if-present --",
    "build:split": "npm run build:templates && npm run build:backend && npm run build:frontend",
    "lint": "npm run lint:split",
    "lint:backend": "npm run lint --workspace backend --if-present --",
    "lint:frontend": "npm run lint --workspace frontend --if-present --",
    "lint:split": "npm run lint:backend && npm run lint:frontend"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.0"
  }
}
