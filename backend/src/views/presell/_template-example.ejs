<%- include('includes/head', { title: title, pixelHtml: pixelHtml }) %>
<body class="public-body <%= presell.template %>-body">

  <main class="<%= presell.template %>-shell">
    <div class="<%= presell.template %>-card">
      <!-- Eyebrow (optional) -->
      <%- include('includes/eyebrow-headline', { 
        eyebrow: 'Novo Template',
        headlineClass: presell.template + '-headline',
        subtitle: presell.subtitle,
        subtitleClass: presell.template + '-subtitle'
      }) %>
      
      <!-- Hero Image (optional) -->
      <%- include('includes/hero-image', { 
        presell: presell, 
        imageClass: presell.template + '-image'
      }) %>
      
      <!-- Body Content -->
      <% if (presell.body) { %>
        <div class="<%= presell.template %>-body-copy"><%= presell.body %></div>
      <% } %>
      
      <!-- Benefits/Bullets (optional) -->
      <%- include('includes/benefits', { 
        bullets: bullets, 
        listClass: presell.template + '-bullets'
      }) %>
      
      <!-- CTA Button -->
      <%- include('includes/cta-button', { 
        presell: presell,
        preview: preview,
        trackingQuery: trackingQuery,
        buttonClass: presell.template + '-cta',
        ctaText: presell.cta_text
      }) %>
    </div>
  </main>
</body>
</html>