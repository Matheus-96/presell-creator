PORT=3000
# Optional split port for backend workspace commands (`npm run start:backend`)
# BACKEND_PORT=3002
APP_URL=http://localhost:3000
# Backend serves the built React admin from this path when frontend/dist exists.
# ADMIN_FRONTEND_PATH=/admin-app
# Legacy SSR admin stays here. For a real cutover, swap these paths.
# LEGACY_ADMIN_PATH=/admin
# Optional React-only hint for legacy fallback links shown inside the SPA.
# VITE_LEGACY_ADMIN_URL=/admin
SESSION_SECRET=change-this-session-secret
# Secure cookie defaults auto-enable in production. Override explicitly when needed.
# FORCE_HTTPS=false
# TRUST_PROXY=1
# SESSION_COOKIE_SECURE=auto
# SESSION_COOKIE_SAME_SITE=lax
ADMIN_USER=admin
# Generate with: npm run hash-password -- "your-password"
ADMIN_PASSWORD_HASH=scrypt:32768:8:1:exampleSalt:exampleHash
NODE_ENV=development
