# Repo-root runtime source of truth for both backend startup and frontend builds.
NODE_ENV=production
BACKEND_PORT=3002

# Optional split port for backend workspace commands (`npm run start:backend`).
# Leave unset to reuse PORT.
# BACKEND_PORT=3002
APP_URL=https://presell.example.com

# Same-origin admin routing defaults. Keep the React bundle beside the legacy SSR admin
# until the cutover is complete.
ADMIN_FRONTEND_PATH=/admin-app
LEGACY_ADMIN_PATH=/admin
VITE_APP_NAME=Presell Creator Admin
VITE_API_BASE_URL=/api
VITE_AUTH_MODE=session
# This stays relative to VITE_API_BASE_URL, so /admin/session resolves to /api/admin/session.
VITE_AUTH_SESSION_PATH=/admin/session
# Keep the React fallback link aligned with LEGACY_ADMIN_PATH.
VITE_LEGACY_ADMIN_URL=/admin
# Cutover example:
# ADMIN_FRONTEND_PATH=/admin
# LEGACY_ADMIN_PATH=/admin-legacy
# VITE_LEGACY_ADMIN_URL=/admin-legacy

SESSION_SECRET=change-this-session-secret
# Cloudflare Tunnel -> lighttpd -> PM2/backend proxy chain.
TRUST_PROXY=1
SESSION_COOKIE_SECURE=auto
SESSION_COOKIE_SAME_SITE=lax
# Optional override if HTTPS headers are stripped before Express sees the request.
# FORCE_HTTPS=true

ADMIN_USER=admin
# Generate with: npm run hash-password -- "your-password"
ADMIN_PASSWORD_HASH=scrypt:32768:8:1:exampleSalt:exampleHash

# AI / page extraction
OPENROUTER_API_KEY=
PAGE_EXTRACTOR=puppeteer
