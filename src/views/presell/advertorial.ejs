<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %></title>
  <link rel="stylesheet" href="/static/styles.css">
</head>
<body class="public-body">
  <main class="article-shell">
    <article class="article">
      <p class="eyebrow">Especial</p>
      <h1><%= presell.headline %></h1>
      <% if (presell.subtitle) { %><p class="lead"><%= presell.subtitle %></p><% } %>
      <% if (presell.image_path) { %><img class="hero-img" src="/media/<%= presell.image_path %>" alt=""><% } %>
      <div class="copy"><%- nl2br(presell.body) %></div>
      <% if (bullets.length) { %>
        <ul class="benefits">
          <% bullets.forEach(function(item) { %><li><%= item %></li><% }) %>
        </ul>
      <% } %>
      <a class="cta" href="<%= preview ? '#' : '/go/' + presell.slug %>"><%= presell.cta_text %></a>
      <p class="disclaimer">Conteudo informativo. Ao continuar, voce sera direcionado para a pagina oficial da oferta.</p>
    </article>
  </main>
</body>
</html>
