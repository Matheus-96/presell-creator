<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %></title>
  <link rel="stylesheet" href="/static/styles.css">
  <%- pixelHtml %>
</head>
    <section class="quiz-card">
      <p class="eyebrow">Quiz rapido</p>
      <h1><%= presell.headline %></h1>
      <% if (presell.subtitle) { %><p class="lead"><%= presell.subtitle %></p><% } %>
      <% if (presell.image_path) { %><img class="hero-img" src="/media/<%= presell.image_path %>" alt=""><% } %>
      <div class="copy"><%- nl2br(presell.body) %></div>
      <div class="quiz-options">
        <% (bullets.length ? bullets : ['Sim, quero ver a recomendacao', 'Quero entender melhor']).forEach(function(item) { %>
          <a href="<%= preview ? '#' : '/go/' + presell.slug %>"><%= item %></a>
        <% }) %>
      </div>
      <a class="cta secondary" href="<%= preview ? '#' : '/go/' + presell.slug %>"><%= presell.cta_text %></a>
    </section>
  </main>
</body>
</html>
