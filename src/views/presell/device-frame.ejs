<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %></title>
  <link rel="stylesheet" href="/static/styles.css">
  <%- pixelHtml %>
</head>
<body class="public-body device-frame-body">
  <%
    var deviceCtaHref = preview ? '#' : '/go/' + presell.slug + trackingQuery;
    var deviceFrameType = settings.frame_type || 'browser';
    var deviceTopBarText = settings.top_bar_text || '';
    var deviceFooterLeftText = settings.footer_left_text || '';
    var deviceFooterRightText = settings.footer_right_text || '';
    var deviceOfferNote = settings.offer_note || '';
    var deviceBullets = bullets.slice(0, 3);
  %>
  <main class="device-frame-shell device-frame-shell-<%= deviceFrameType %>">
    <section class="device-frame-stage">
      <article class="device-frame-window device-frame-window-<%= deviceFrameType %>">
        <header class="device-frame-top-bar">
          <div class="device-frame-controls" aria-hidden="true">
            <span class="device-frame-control"></span>
            <span class="device-frame-control"></span>
            <span class="device-frame-control"></span>
          </div>
          <% if (deviceTopBarText) { %>
            <p class="device-frame-top-text"><%= deviceTopBarText %></p>
          <% } %>
        </header>

        <div class="device-frame-content">
          <% if (presell.image_path) { %>
            <figure class="device-frame-media">
              <img class="device-frame-image" src="/media/<%= presell.image_path %>" alt="">
            </figure>
          <% } %>

          <section class="device-frame-copy">
            <% if (deviceOfferNote) { %>
              <p class="device-frame-offer-note"><%= deviceOfferNote %></p>
            <% } %>
            <h1 class="device-frame-headline"><%= presell.headline %></h1>
            <% if (presell.subtitle) { %>
              <p class="device-frame-subtitle"><%= presell.subtitle %></p>
            <% } %>
            <% if (deviceBullets.length) { %>
              <ul class="device-frame-bullets">
                <% deviceBullets.forEach(function(item) { %>
                  <li class="device-frame-bullet"><%= item %></li>
                <% }) %>
              </ul>
            <% } %>
            <a class="device-frame-cta" href="<%= deviceCtaHref %>"><%= presell.cta_text %></a>
          </section>
        </div>

        <% if (deviceFooterLeftText || deviceFooterRightText) { %>
          <footer class="device-frame-footer">
            <span class="device-frame-footer-left"><%= deviceFooterLeftText %></span>
            <span class="device-frame-footer-right"><%= deviceFooterRightText %></span>
          </footer>
        <% } %>
      </article>
    </section>
  </main>
</body>
</html>
