<%- include('_header') %>

<header class="admin-header">
  <div>
    <strong>Estatísticas: <%= presell.title %></strong>
    <a class="muted" href="/admin">voltar ao painel</a>
  </div>
  <div class="d-flex gap-2">
    <a class="btn btn-outline-primary btn-sm" href="/admin/presells/<%= presell.id %>/edit">
      <i class="bi bi-pencil"></i> Editar
    </a>
    <a class="btn btn-outline-info btn-sm" href="/p/<%= presell.slug %>" target="_blank">
      <i class="bi bi-box-arrow-up-right"></i> Ver Página
    </a>
  </div>
</header>

<main class="admin-main">
  <!-- Summary Cards -->
  <div class="container-fluid px-4 py-4">
    <div class="row g-4 mb-4">
      <div class="col-12 col-md-3">
        <div class="card shadow-sm border-0 h-100">
          <div class="card-body text-center">
            <p class="text-muted small mb-1">👁️ Views</p>
            <h3 class="mb-0"><%= stats.summary.views %></h3>
          </div>
        </div>
      </div>
      <div class="col-12 col-md-3">
        <div class="card shadow-sm border-0 h-100">
          <div class="card-body text-center">
            <p class="text-muted small mb-1">🖱️ Cliques</p>
            <h3 class="mb-0"><%= stats.summary.clicks %></h3>
          </div>
        </div>
      </div>
      <div class="col-12 col-md-3">
        <div class="card shadow-sm border-0 h-100">
          <div class="card-body text-center">
            <p class="text-muted small mb-1">🔗 Redirects</p>
            <h3 class="mb-0"><%= stats.summary.redirects %></h3>
          </div>
        </div>
      </div>
      <div class="col-12 col-md-3">
        <div class="card shadow-sm border-0 h-100">
          <div class="card-body text-center">
            <p class="text-muted small mb-1">📊 CTR</p>
            <h3 class="mb-0 text-primary"><%= stats.summary.ctr.toFixed(1) %>%</h3>
          </div>
        </div>
      </div>
    </div>

    <!-- Time Series Chart -->
    <div class="card shadow-sm border-0 mb-4">
      <div class="card-header bg-white">
        <h5 class="mb-0"><i class="bi bi-graph-up"></i> Views e Cliques (Últimos 30 dias)</h5>
      </div>
      <div class="card-body">
        <canvas id="timeSeriesChart" style="max-height: 300px;"></canvas>
      </div>
    </div>

    <div class="row g-4 mb-4">
      <!-- GCLID Stats -->
      <div class="col-12 col-lg-6">
        <div class="card shadow-sm border-0 h-100">
          <div class="card-header bg-white">
            <h5 class="mb-0"><i class="bi bi-google"></i> GCLIDs (Google Ads)</h5>
          </div>
          <div class="card-body p-0">
            <div class="table-responsive">
              <table class="table table-hover table-sm mb-0">
                <thead class="table-light">
                  <tr>
                    <th class="px-3">GCLID</th>
                    <th class="text-center">Views</th>
                    <th class="text-center">Cliques</th>
                    <th class="text-center">Redirects</th>
                    <th class="text-end px-3">Total</th>
                  </tr>
                </thead>
                <tbody>
                  <% stats.gclidStats.forEach(function(item) { %>
                    <tr>
                      <td class="px-3">
                        <small class="text-muted font-monospace"><%= item.gclid %></small>
                      </td>
                      <td class="text-center"><%= item.views %></td>
                      <td class="text-center"><%= item.clicks %></td>
                      <td class="text-center"><%= item.redirects %></td>
                      <td class="text-end px-3">
                        <span class="badge bg-primary"><%= item.total_events %></span>
                      </td>
                    </tr>
                  <% }) %>
                  <% if (stats.gclidStats.length === 0) { %>
                    <tr>
                      <td colspan="5" class="text-center text-muted py-3">Nenhum GCLID encontrado</td>
                    </tr>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>

      <!-- UTM Sources -->
      <div class="col-12 col-lg-6">
        <div class="card shadow-sm border-0 h-100">
          <div class="card-header bg-white">
            <h5 class="mb-0"><i class="bi bi-globe"></i> UTM Sources</h5>
          </div>
          <div class="card-body p-0">
            <div class="table-responsive">
              <table class="table table-hover table-sm mb-0">
                <thead class="table-light">
                  <tr>
                    <th class="px-3">Source</th>
                    <th class="text-end px-3">Views</th>
                  </tr>
                </thead>
                <tbody>
                  <% stats.utmSources.forEach(function(item) { %>
                    <tr>
                      <td class="px-3">
                        <span class="badge bg-light text-dark"><%= item.source %></span>
                      </td>
                      <td class="text-end px-3"><strong><%= item.total %></strong></td>
                    </tr>
                  <% }) %>
                  <% if (stats.utmSources.length === 0) { %>
                    <tr>
                      <td colspan="2" class="text-center text-muted py-3">Nenhuma UTM source encontrada</td>
                    </tr>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Top Referrers -->
    <div class="card shadow-sm border-0 mb-4">
      <div class="card-header bg-white">
        <h5 class="mb-0"><i class="bi bi-link-45deg"></i> Top Referrers</h5>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover table-sm mb-0">
            <thead class="table-light">
              <tr>
                <th class="px-3">Referrer</th>
                <th class="text-end px-3">Visitas</th>
              </tr>
            </thead>
            <tbody>
              <% stats.referrers.forEach(function(item) { %>
                <tr>
                  <td class="px-3">
                    <small class="text-muted"><%= item.referrer %></small>
                  </td>
                  <td class="text-end px-3"><strong><%= item.total %></strong></td>
                </tr>
              <% }) %>
              <% if (stats.referrers.length === 0) { %>
                <tr>
                  <td colspan="2" class="text-center text-muted py-3">Nenhum referrer encontrado</td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Recent Events Timeline -->
    <div class="card shadow-sm border-0">
      <div class="card-header bg-white">
        <h5 class="mb-0"><i class="bi bi-clock-history"></i> Timeline de Eventos</h5>
      </div>
      <div class="card-body">
        <div class="event-list">
          <% stats.recentEvents.forEach(function(event) { %>
            <div class="d-flex justify-content-between align-items-start mb-3 pb-3 border-bottom">
              <div class="flex-grow-1">
                <p class="mb-1">
                  <span class="badge bg-<%= event.event_type === 'page_view' ? 'info' : event.event_type === 'cta_click' ? 'warning' : 'success' %> text-dark">
                    <%= event.event_type %>
                  </span>
                  <% if (event.params_json) { 
                    try {
                      var params = JSON.parse(event.params_json);
                      if (params.gclid) { %>
                        <span class="badge bg-light text-dark"><i class="bi bi-google"></i> GCLID</span>
                      <% }
                    } catch(e) {}
                  } %>
                </p>
                <small class="text-muted"><%= event.created_at %></small>
              </div>
            </div>
          <% }) %>
          <% if (stats.recentEvents.length === 0) { %>
            <p class="text-center text-muted py-3">Nenhum evento registrado</p>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</main>

<!-- Chart.js CDN -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
  (function() {
    var ctx = document.getElementById('timeSeriesChart').getContext('2d');
    
    var labels = <%- timeSeriesLabels %>;
    var viewsData = <%- timeSeriesViews %>;
    var clicksData = <%- timeSeriesClicks %>;
    
    new Chart(ctx, {
      type: 'line',
      data: {
        labels: labels,
        datasets: [{
          label: 'Views',
          data: viewsData,
          borderColor: '#176b5b',
          backgroundColor: 'rgba(23, 107, 91, 0.1)',
          tension: 0.1,
          fill: true
        }, {
          label: 'Cliques',
          data: clicksData,
          borderColor: '#0d4d41',
          backgroundColor: 'rgba(13, 77, 65, 0.1)',
          tension: 0.1,
          fill: true
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        scales: {
          y: { beginAtZero: true }
        }
      }
    });
  })();
</script>

<%- include('_footer') %>

