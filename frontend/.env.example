# Documentation mirror only: Vite reads these from the repo-root .env via envDir=..
VITE_APP_NAME="Presell Creator Admin"
VITE_API_BASE_URL="/api"
VITE_LEGACY_ADMIN_URL="/admin"
VITE_AUTH_MODE="session"
# Combined with VITE_API_BASE_URL=/api, this resolves to /api/admin/session.
VITE_AUTH_SESSION_PATH="/admin/session"
# Development-only proxy target for `npm run dev:frontend`.
DEV_PROXY_TARGET="http://127.0.0.1:3001"
